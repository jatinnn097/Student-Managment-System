<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Student</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>

<div class="form-card">
    <h2>ADD A NEW STUDENT</h2>

    <form action="/add" method="POST" enctype="multipart/form-data">

        <input type="text" name="usn" placeholder="USN" required>

        <input type="text" name="fullname" placeholder="Full Name" required>

        <input type="text" name="branch" placeholder="Branch" required>
        <input type="email" name="email" placeholder="Email" required>

        <input type="number" name="sem" placeholder="Semester" min="1" max="8" required>

        <input type="number" name="cgpa" step="0.01" placeholder="CGPA" required>

        <input type="file" name="photo" accept="image/*" required>

        <button type="submit" class="submit">Add Student</button>

    </form>
</div>

</body>
</html>