<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Semester Result</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial,sans-serif;
        }

        body{
            background:#f4f4f4;
            padding:40px;
        }

        .container{
            max-width:900px;
            margin:auto;
            background:#fff;
            border-radius:10px;
            padding:30px;
            box-shadow:0 5px 15px rgba(0,0,0,.2);
        }

        h1{
            text-align:center;
            color:#0b5d5d;
            margin-bottom:20px;
        }

        h2{
            text-align:center;
            margin-bottom:20px;
        }

        table{
            width:100%;
            border-collapse:collapse;
            margin-top:20px;
        }

        th{
            background:#0b5d5d;
            color:#fff;
            padding:12px;
        }

        td{
            padding:12px;
            border:1px solid #ddd;
            text-align:center;
        }

        tr:nth-child(even){
            background:#f8f8f8;
        }

        .summary{
            margin-top:25px;
            text-align:center;
            font-size:18px;
            font-weight:bold;
        }

        .message{
            text-align:center;
            color:red;
            font-size:22px;
            margin:30px 0;
        }

        .center{
            text-align:center;
            margin-top:30px;
        }

        .btn{
            display:inline-block;
            padding:12px 25px;
            background:#0b5d5d;
            color:white;
            text-decoration:none;
            border-radius:5px;
        }

        .btn:hover{
            background:#084444;
        }

    </style>
</head>
<body>

<div class="container">

<% if(student){ %>

    <h1>Student Semester Result</h1>

    <h2>
        <%= student.fullname %> (<%= student.usn %>)
    </h2>

    <% if(result){ %>

        <h2>Semester <%= sem %></h2>

        <table>
            <tr>
                <th>Subject</th>
                <th>Marks</th>
            </tr>

            <% result.subjects.forEach(function(subject){ %>
            <tr>
                <td><%= subject.subject %></td>
                <td><%= subject.marks %></td>
            </tr>
            <% }) %>

        </table>

        <div class="summary">
            Percentage : <%= result.percentage %>%<br><br>
            CGPA : <%= result.cgpa %>
        </div>

    <% } else { %>

        <div class="message">
            Result Not Published Yet
        </div>

    <% } %>

    <div class="center">
        <a href="/student/<%= student.usn %>" class="btn">Back</a>
    </div>

<% } else { %>

    <div class="message">
        Student Not Found
    </div>

    <div class="center">
        <a href="/" class="btn">Go to Login</a>
    </div>

<% } %>

</div>

</body>
</html>