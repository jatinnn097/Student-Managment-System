<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Student</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, Helvetica, sans-serif;
        }

        body{
            background:#f4f4f4;
            display:flex;
            justify-content:center;
            align-items:center;
            min-height:100vh;
        }

        .form-card{
            width:450px;
            background:#fff;
            padding:35px;
            border-radius:12px;
            box-shadow:0 8px 20px rgba(0,0,0,.15);
        }

        h2{
            text-align:center;
            color:#055a5a;
            margin-bottom:25px;
            font-size:32px;
        }

        form{
            display:flex;
            flex-direction:column;
            gap:18px;
        }

        input{
            width:100%;
            padding:14px;
            border:1px solid #ccc;
            border-radius:8px;
            font-size:16px;
            outline:none;
            transition:.3s;
        }

        input:focus{
            border-color:#055a5a;
            box-shadow:0 0 6px rgba(5,90,90,.3);
        }

        label{
            color:#055a5a;
            font-weight:bold;
            margin-top:5px;
        }

        input[type="file"]{
            border:none;
            padding:5px 0;
        }

        button{
            background:#055a5a;
            color:white;
            border:none;
            padding:14px;
            border-radius:8px;
            font-size:18px;
            cursor:pointer;
            transition:.3s;
        }

        button:hover{
            background:#044747;
        }

        .back-btn{
            display:block;
            margin-top:20px;
            text-align:center;
            text-decoration:none;
            background:#666;
            color:white;
            padding:12px;
            border-radius:8px;
            transition:.3s;
        }

        .back-btn:hover{
            background:#444;
        }
    </style>

</head>
<body>

<div class="form-card">

    <h2>Edit Student</h2>

    <form action="/edit/<%= student.usn %>" method="POST" enctype="multipart/form-data">

        <input
            type="text"
            name="fullname"
            placeholder="Full Name"
            value="<%= student.fullname %>"
            required
        >

        <input
            type="text"
            name="branch"
            placeholder="Branch"
            value="<%= student.branch %>"
            required
        >

        <input
            type="number"
            name="sem"
            placeholder="Semester"
            value="<%= student.sem %>"
            required
        >

        <input
            type="text"
            name="cgpa"
            placeholder="CGPA"
            value="<%= student.cgpa %>"
            required
        >

        <label>Upload New Photo</label>

        <input
            type="file"
            name="photo"
            accept="image/*"
        >

        <button type="submit">Update Student</button>

    </form>

    <a href="/admin" class="back-btn">← Back to Dashboard</a>

</div>

</body>
</html>