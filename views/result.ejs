<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Result</title>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap');

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:"Montserrat",sans-serif;
        }

        body{
            background:#f4f4f4;
        }

        .container{
            width:90%;
            margin:30px auto;
        }

        h2{
            text-align:center;
            color:rgb(0,77,77);
            margin-bottom:10px;
        }

        h3{
            text-align:center;
            margin-bottom:20px;
            color:#444;
        }

        .form-card{
            max-width:800px;
            margin:auto;
            background:#fff;
            padding:30px;
            border-radius:10px;
            box-shadow:0 5px 15px rgba(0,0,0,.2);
        }

        label{
            display:block;
            margin:15px 0 8px;
            font-weight:bold;
        }

        select,
        input{
            width:100%;
            padding:12px;
            border:1px solid #ccc;
            border-radius:5px;
            font-size:15px;
        }

        table{
            width:100%;
            border-collapse:collapse;
            margin-top:20px;
        }

        table th{
            background:rgb(0,77,77);
            color:#fff;
            padding:12px;
        }

        table td{
            border:1px solid #ddd;
            padding:10px;
        }

        table input{
            margin:0;
        }

        button{
            width:100%;
            padding:12px;
            margin-top:20px;
            background:rgb(0,77,77);
            color:#fff;
            border:none;
            border-radius:5px;
            font-size:16px;
            cursor:pointer;
        }

        button:hover{
            background:rgb(0,100,100);
        }

        .error{
            color:red;
            text-align:center;
            margin-top:30px;
        }
    </style>
</head>
<body>

<div class="container">

<% if(student){ %>

<h2>Add Result of <%= student.fullname %></h2>
<h3>USN : <%= student.usn %></h3>

<div class="form-card">

<form action="/result/<%= student.usn %>" method="POST">

<label>Semester</label>

<select name="semester" required>
    <option value="">Select Semester</option>
    <option value="1">Semester 1</option>
    <option value="2">Semester 2</option>
    <option value="3">Semester 3</option>
    <option value="4">Semester 4</option>
    <option value="5">Semester 5</option>
    <option value="6">Semester 6</option>
    <option value="7">Semester 7</option>
    <option value="8">Semester 8</option>
</select>

<table>
    <tr>
        <th>Subject</th>
        <th>Marks</th>
    </tr>

   <tr>
    <td><input type="text" name="sub1" placeholder="Subject 1" required></td>
    <td><input type="number" name="mark1" class="marks" min="0" max="100" required></td>
</tr>

<tr>
    <td><input type="text" name="sub2" placeholder="Subject 2" required></td>
    <td><input type="number" name="mark2" class="marks" min="0" max="100" required></td>
</tr>

<tr>
    <td><input type="text" name="sub3" placeholder="Subject 3" required></td>
    <td><input type="number" name="mark3" class="marks" min="0" max="100" required></td>
</tr>

<tr>
    <td><input type="text" name="sub4" placeholder="Subject 4" required></td>
    <td><input type="number" name="mark4" class="marks" min="0" max="100" required></td>
</tr>

<tr>
    <td><input type="text" name="sub5" placeholder="Subject 5" required></td>
    <td><input type="number" name="mark5" class="marks" min="0" max="100" required></td>
</tr>

<tr>
    <td><input type="text" name="sub6" placeholder="Subject 6" required></td>
    <td><input type="number" name="mark6" class="marks" min="0" max="100" required></td>
</tr>
</table>

<br>

<label>Percentage</label>
<input type="number" id="percentage" name="percentage" step="0.01" readonly>

<label>CGPA</label>
<input type="number" id="cgpa" name="cgpa" step="0.01" readonly>

<button type="submit">Publish Result</button>

</form>

</div>

<% } else { %>

<h2 class="error">Student Not Found!</h2>

<% } %>

</div>
<script>
function calculateResult() {

    let total = 0;

    document.querySelectorAll(".marks").forEach(function(input){
        total += parseFloat(input.value) || 0;
    });

    let percentage = (total / 600) * 100;
    let cgpa = percentage / 9.5;

    document.getElementById("percentage").value =
        total > 0 ? percentage.toFixed(2) : "";

    document.getElementById("cgpa").value =
        total > 0 ? cgpa.toFixed(2) : "";
}

document.querySelectorAll(".marks").forEach(function(input){
    input.addEventListener("input", calculateResult);
});
</script>
</body>
</html>